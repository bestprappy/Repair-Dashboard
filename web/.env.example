# Copy to .env.local. Google Sheet the dashboard loads live on startup;
# leave unset to fall back to the manual CSV upload flow.
# The sheet must be shared as "Anyone with the link can view".
NEXT_PUBLIC_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing

# Server-only dashboard password. Never prefix this variable with NEXT_PUBLIC_.
# Use a long, unique value (20+ random characters recommended).
AUTH_PASSWORD=replace-with-a-long-random-password
